# Copy to bot/.env on the VPS and fill in real values.
# bot/.env is gitignored — never commit secrets.
#
# Confirm variable names against bot.py after pulling the source down;
# adjust this template if the bot uses different names.

# Alpaca API (paper trading)
# Generate at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Mode flags
TRADING_ENABLED=false
PAPER_TRADING=true

# Alerts (Phase 3)
ALERT_EMAIL=okipapa@me.com

# Earnings data (Phase 3, optional)
# MORNINGSTAR_API_KEY=
# FMP_API_KEY=
